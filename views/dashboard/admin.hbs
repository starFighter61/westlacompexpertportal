<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h2">Admin Dashboard</h1>
    <p>Overview of the client portal.</p>
  </div>
  <div>
    <form action="/dashboard/admin" method="GET" class="d-flex align-items-center" id="timeframeForm">
      <label for="timeframe" class="me-2 fw-bold">Filter By:</label>
      <select name="timeframe" id="timeframe" class="form-select w-auto"
        onchange="document.getElementById('timeframeForm').submit()">
        <option value="all" {{#ifEquals timeframe 'all' }}selected{{/ifEquals}}>All Time</option>
        <option value="year" {{#ifEquals timeframe 'year' }}selected{{/ifEquals}}>This Year</option>
        <option value="month" {{#ifEquals timeframe 'month' }}selected{{/ifEquals}}>This Month</option>
        <option value="week" {{#ifEquals timeframe 'week' }}selected{{/ifEquals}}>This Week</option>
      </select>
    </form>
  </div>
</div>

<div class="row">
  <!-- User Stats -->
  <div class="col-md-4 mb-4">
    <div class="card text-center h-100">
      <div class="card-body">
        <i class="fas fa-users fa-3x text-primary mb-3"></i>
        <h5 class="card-title">Total Users</h5>
        <p class="card-text display-6">{{add clientCount technicianCount}}</p>
        <small class="text-muted">{{clientCount}} Clients | {{technicianCount}} Technicians</small>
      </div>
    </div>
  </div>

  <!-- Service Stats -->
  <div class="col-md-4 mb-4">
    <div class="card text-center h-100">
      <div class="card-body">
        <i class="fas fa-tools fa-3x text-success mb-3"></i>
        <h5 class="card-title">Services</h5>
        <p class="card-text display-6">{{serviceCount}}</p>
        <small class="text-muted">{{completedServiceCount}} Completed</small>
      </div>
    </div>
  </div>

  <!-- Invoice Stats -->
  <div class="col-md-4 mb-4">
    <div class="card text-center h-100">
      <div class="card-body">
        <i class="fas fa-file-invoice-dollar fa-3x text-warning mb-3"></i>
        <h5 class="card-title">Invoice Totals</h5>
        <p class="card-text display-6">{{formatCurrency invoiceStats.totalAmount}}</p>
        <small class="text-muted">
          {{formatCurrency invoiceStats.paidAmount}} Paid | {{formatCurrency invoiceStats.unpaidAmount}} Unpaid
        </small>
      </div>
    </div>
  </div>
</div>

<!-- Revenue Chart Row -->
<div class="row mb-4">
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-header bg-white border-bottom">
        <h5 class="card-title mb-0">Revenue Timeline</h5>
      </div>
      <div class="card-body">
        <canvas id="revenueChart" width="400" height="100"></canvas>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-12">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Admin Actions</h5>
      </div>
      <div class="card-body">
        <a href="/users/manage" class="btn btn-primary me-2">Manage Users</a>
        <a href="/services" class="btn btn-secondary me-2">View All Services</a>
        <a href="/invoices" class="btn btn-info me-2">View All Invoices</a>
        <a href="/settings" class="btn btn-warning">System Settings</a>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const rawChartData = {{{ chartData }
  }};
  console.log("Chart Data:", rawChartData);

  if (rawChartData && rawChartData.labels.length > 0) {
    const ctx = document.getElementById('revenueChart').getContext('2d');
    new Chart(ctx, {
      type: 'line',
      data: {
        labels: rawChartData.labels,
        datasets: [{
          label: 'Total Invoiced ($)',
          data: rawChartData.values,
          borderColor: 'rgba(54, 162, 235, 1)',
          backgroundColor: 'rgba(54, 162, 235, 0.2)',
          borderWidth: 2,
          tension: 0.3,
          fill: true
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: {
            display: true,
            position: 'top',
          },
          tooltip: {
            callbacks: {
              label: function (context) {
                let label = context.dataset.label || '';
                if (label) {
                  label += ': ';
                }
                if (context.parsed.y !== null) {
                  label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(context.parsed.y);
                }
                return label;
              }
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: function (value, index, values) {
                return '$' + value;
              }
            }
          }
        }
      }
    });
  } else {
    // Handle empty data case
    const ctx = document.getElementById('revenueChart').getContext('2d');
    ctx.font = '16px Arial';
    ctx.textAlign = 'center';
    ctx.fillStyle = '#666';
    ctx.fillText('No revenue data available for this timeframe.', 200, 50);
  }
  });
</script>